# Bridle needs NO API keys: speech-to-text runs offline in the browser
# (Whisper via Transformers.js) and text-to-speech uses the browser's built-in
# speech synthesis. The desktop holds no secrets.

# Optional overrides (desktop)
# BRIDLE_BACKEND_URL=https://bridle.3sln.com

# --- Backend (Cloudflare Worker) TURN secrets ---------------------------------
# Optional. Only the *backend* needs these, and they are set with
# `wrangler secret put` (NOT this file). Listed here for reference. Without them,
# the TURN backup relay stays off and only free STUN + OpenRelay are handed out.
# Budget/rate limits live in packages/worker/wrangler.toml [vars].
#
#   TURN_KEY_ID            # Cloudflare Realtime TURN app key id
#   TURN_KEY_API_TOKEN     # its API token (mints short-lived credentials)
#   TURN_ANALYTICS_TOKEN   # optional: API token with "Account Analytics" for a
#                          # real (not estimated) monthly-GB budget gate
#   CF_ACCOUNT_ID          # optional: required alongside TURN_ANALYTICS_TOKEN
